# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ── Supabase (auth only — all data goes through the Worker) ──────────────────
# Project Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Project Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudflare Worker ────────────────────────────────────────────────────────
# The URL of your deployed Worker (from `wrangler deploy` output)
VITE_WORKER_URL=https://lc-sync-worker.YOUR-SUBDOMAIN.workers.dev

# ── Sync tuning (optional) ───────────────────────────────────────────────────
# How long to wait before auto-saving after a change (milliseconds). Default: 300000 (5 min)
# VITE_SYNC_BATCH_MS=300000

# ── Optional ─────────────────────────────────────────────────────────────────
# Comma-separated list of email addresses granted admin access (move/copy/delete problems)
# VITE_ADMIN_EMAILS=you@example.com,colleague@example.com
